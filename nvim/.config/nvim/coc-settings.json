{
  "coc.preferences.extensionUpdateCheck": "daily",
  "coc.preferences.formatOnSaveFiletypes": [
    "typescript",
    "typescript.tsx",
    "Markdown",
    "rust",
    "terraform"
  ],
  "languageserver": {
    "terraform": {
      "command": "terraform-ls",
			"args": ["serve"],
			"filetypes": [
				"terraform",
				"tf"
			],
      "initializationOptions": {}
    },
    "metals": {
      "command": "metals-vim",
      "rootPatterns": [
        "build.sbt"
      ],
      "filetypes": [
        "scala",
        "sbt"
      ]
    }
  }
}
