[user]
	name = Christian Mösl
	email = christian.moesl@e-mundo.de
	signingkey = 88D26A2DA47C2BFE
[core]
	editor = nvim
[commit]
	gpgsign = true
[gpg]
	program = gpg
[diff]
	tool = vimdiff
[merge]
	tool = vimdiff
[difftool]
	prompt = false
[mergetool]
	prompt = false
[mergetool "vimdiff"]
	path = nvim
[difftool "vimdiff"]
	path = nvim
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[pull]
	rebase = true
